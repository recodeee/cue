{
  "name": "cue-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local + Vercel-deployable dashboard for cue. Reads from the cue dashboard server (local) or a static demo-data.json (Vercel demo).",
  "scripts": {
    "dev": "vite",
    "dev:full": "bun ../scripts/dashboard-dev.ts",
    "build": "vite build",
    "preview": "vite preview",
    "gen-demo-data": "bun ../scripts/dashboard-demo-data.ts > public/demo-data.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tanstack/react-query": "^5.51.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
